# Copy to .env on the host (chmod 600). NEVER commit .env (git-ignored).
# Add the matching field in main.py Settings BEFORE adding a var here —
# pydantic-settings extra="ignore" silently drops unmatched vars.
# After ANY .env change use `up -d` (recreates), NOT `restart`.

TMDB_TOKEN=                 # TMDB v4 read token (Settings -> API)
MDBLIST_API_KEY=           # mdblist.com -> Preferences -> API
TRAKT_CLIENT_ID=           # trakt.tv -> Settings -> Your API Apps (client id)
TRAKT_CLIENT_SECRET=       # ...same app (client secret)
SEERR_BASE=http://seerr:5055
SEERR_API_KEY=             # Seerr -> Settings -> General

# Trakt OAuth user tokens are NOT set here — mint them once via the device flow
# (see app/README or handoff), they're stored in /data/discov.db and auto-refreshed.
